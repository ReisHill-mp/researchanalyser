# Copy this file to .env.local and replace the placeholder values.
# Keep .env.local out of git.

# Supabase
# Required for loading projects, transcripts, analysis runs, reports, and imports.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-secret-key

# OpenAI
# Required for AI analysis, project chat, and AI-regenerated reports.
OPENAI_API_KEY=your-openai-api-key

# Optional Supabase compatibility aliases
# The app and local scripts can read these if the NEXT_PUBLIC_* values are not set.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional database connection string
# Not read by the app directly, but useful if you copy env vars from Vercel/Supabase.
# POSTGRES_URL=postgresql://postgres:your-password@your-host:5432/postgres
